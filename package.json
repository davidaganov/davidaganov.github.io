{
  "name": "portfolio",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build && tsx scripts/sync-rss-og-images.ts && nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "prepare": "husky",
    "postinstall": "nuxt prepare && npm run build:docs-assets",
    "lint": "run-s lint:*",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prod": "run-s format lint:fix translate",
    "typecheck": "nuxt typecheck",
    "translate": "npx polyglot-keeper sync",
    "translate:md": "npx polyglot-keeper sync --md",
    "translate:init": "npx polyglot-keeper init",
    "generate:favicons": "tsx scripts/generate-favicons.ts",
    "build:docs-assets": "tsx scripts/build-docs-assets.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/lucide": "^1.2.109",
    "@iconify-json/simple-icons": "^1.2.83",
    "@nuxt/content": "^3.14.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/ui": "^4.8.0",
    "@nuxtjs/i18n": "^10.4.0",
    "@nuxtjs/robots": "^6.0.8",
    "@nuxtjs/seo": "^5.1.3",
    "@nuxtjs/sitemap": "^8.0.15",
    "@pinia/nuxt": "^0.11.3",
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/supabase-js": "^2.106.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/motion": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "d3-force-3d": "^3.0.6",
    "force-graph": "^1.51.4",
    "jszip": "^3.10.1",
    "motion-v": "^2.2.1",
    "nuxt": "^4.4.6",
    "nuxt-link-checker": "^5.0.10",
    "ogl": "^1.0.11",
    "pdfmake": "^0.3.9",
    "satori": "^0.26.0",
    "shiki": "^4.1.0",
    "simplebar-vue": "^2.4.2",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@iconify-json/vscode-icons": "^1.2.50",
    "@nuxt/eslint": "^1.15.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/pdfmake": "^0.3.3",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "favicons": "^7.2.0",
    "husky": "^9.1.7",
    "jsrepo": "^3.7.0",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "nuxt-og-image": "^6.5.1",
    "polyglot-keeper": "^1.3.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vue-tsc": "^3.3.1",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{vue,ts,js,mjs}": "eslint --fix",
    "*.{vue,ts,js,mjs,json,css,md,yml,yaml}": "prettier --write"
  }
}
