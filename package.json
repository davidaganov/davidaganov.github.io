{
  "name": "portfolio",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepare": "husky",
    "postinstall": "nuxt prepare",
    "lint:fix": "eslint . --fix",
    "lint": "run-s lint:*",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prod": "run-s format lint:fix translate",
    "typecheck": "nuxt typecheck",
    "translate": "npx polyglot-keeper sync",
    "translate:md": "npx polyglot-keeper sync --md",
    "translate:init": "npx polyglot-keeper init"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.93",
    "@iconify-json/simple-icons": "^1.2.71",
    "@nuxt/content": "^3.11.2",
    "@nuxt/ui": "^4.4.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@pinia/nuxt": "^0.11.3",
    "@supabase/supabase-js": "^2.98.0",
    "@vueuse/core": "^14.2.1",
    "@vueuse/motion": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "jszip": "^3.10.1",
    "motion-v": "^1.10.3",
    "nuxt": "^4.3.1",
    "ogl": "^1.0.11",
    "shiki": "^3.22.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@iconify-json/vscode-icons": "^1.2.43",
    "@nuxt/eslint": "^1.15.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.3.0",
    "@types/three": "^0.183.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "jsrepo": "^3.6.0",
    "lint-staged": "^16.3.2",
    "npm-run-all2": "^8.0.4",
    "nuxt-og-image": "^5.1.13",
    "polyglot-keeper": "^1.3.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vue-tsc": "^3.2.5"
