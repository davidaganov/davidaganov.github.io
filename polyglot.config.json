{
  "envFile": ".env",
  "json": {
    "provider": "gemini",
    "model": "gemini-flash-latest",
    "envVarName": "VITE_POLYGLOT_API_KEY",
    "localeFormat": "short",
    "locales": [
      "EN",
      "RU"
    ],
    "defaultLocale": "RU",
    "localesDir": "i18n/locales",
    "trackChanges": "carefully"
  },
  "markdown": {
    "contentDir": "content",
    "defaultLocale": "ru",
    "locales": [
      "en",
      "ru"
    ],
    "trackChanges": "carefully",
    "provider": "gemini",
    "model": "gemini-flash-latest",
    "envVarName": "VITE_POLYGLOT_MD_API_KEY"
  }
}
