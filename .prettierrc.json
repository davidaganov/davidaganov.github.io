{
  "semi": false,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": false,
  "trailingComma": "none",
  "arrowParens": "always",
  "jsxSingleQuote": false,
  "bracketSpacing": true,
  "bracketSameLine": false,
  "singleAttributePerLine": true,
  "htmlWhitespaceSensitivity": "ignore",
  "plugins": ["@trivago/prettier-plugin-sort-imports", "prettier-plugin-tailwindcss"],
  "importOrder": [
    "^vue$",
    "^vue/",
    "^#",
    "<THIRD_PARTY_MODULES>",
    "^@(?:app|base|docs|ui|api)/stores",
    "^@/stores",
    "^@(?:app|base|docs|ui|api)/composables",
    "^@/composables",
    "^@(?:app|base|docs|ui|api)/services",
    "^@/services",
    "^@(?:app|base|docs|ui|api)/config",
    "^@/config",
    "^@(?:app|base|docs|ui|api)/utils",
    "^@/utils",
    "^@(?:app|base|docs|ui|api)/constants",
    "^@/constants",
    "^@(?:app|base|docs|ui|api)/plugins",
    "^@/plugins",
    "^@(?:app|base|docs|ui|api)/validation",
    "^@/validation",
    "^@(?:app|base|docs|ui|api)/router",
    "^@/router",
    "^@(?:app|base|docs|ui|api)/layouts",
    "^@/layouts",
    "^@(?:app|base|docs|ui|api)/pages",
    "^@/pages",
    "^@(?:app|base|docs|ui|api)/components",
    "^@/components",
    "^@(?:app|base|docs|ui|api)/types/enums",
    "^@/types/enums",
    "^@(?:app|base|docs|ui|api)/enums",
    "^@/enums",
    "^@(?:app|base|docs|ui|api)/types",
    "^@/types",
    "^@(?:app|base|docs|ui|api)/assets",
    "^@/assets",
    "^@(?:app|base|docs|ui|api)/",
    "^@app/",
    "^@base/",
    "^@docs/",
    "^@ui/",
    "^@api/",
    "^@/",
    "^[./]"
  ],
  "importOrderSideEffects": false,
  "importOrderSeparation": false,
  "importOrderSortSpecifiers": true,
  "importOrderCaseInsensitive": true,
  "importOrderGroupNamespaceSpecifiers": true,
  "endOfLine": "auto"
}
